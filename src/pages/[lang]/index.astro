---
import Layout from '../../layouts/Layout.astro';
import '../../styles/pages/home.css';
import { ui, type Lang } from '../../i18n/translations';

export function getStaticPaths() {
  return [
    { params: { lang: 'fr' } },
    { params: { lang: 'it' } },
    { params: { lang: 'pt' } },
  ];
}

const { lang } = Astro.params;
const t = ui[lang as Lang].home;

const heroImages = [
  '/images/hero/hero-2.jpg',
  '/images/hero/hero-3.jpg',
  '/images/hero/hero-4.jpg',
  '/images/hero/hero-1.jpg',
];

const projectTitles = [
  'Quando sono qui, non sono là',
  'Spilling Beyond the Lines',
  'Toward the Blue',
  'Vedere Venezia e Non Morire',
  'En Corps en la Mer',
];

const projectHrefs = [
  '/work/quando-sono-qui',
  '/work/spilling-beyond-the-lines',
  '/work/toward-the-blue',
  '/work/vedere-venezia',
  '/work/en-corps-en-la-mer',
];

const projectImages = [
  '/images/work/quando-cover.jpg',
  '/images/work/spilling-cover.jpg',
  '/images/work/toward-the-blue-cover.jpg',
  '/images/work/vedere-venezia-cover.jpg',
  '/images/work/en-corps-cover.jpg',
];
---

<Layout
  title="Home"
  description={t.heroLine1}
  lang={lang}
>

  <!-- ─── Hero ─────────────────────────────────────────────── -->
  <section class="hero" aria-label="Hero">

    <div class="hero-bg" aria-hidden="true">
      {heroImages.map((src, i) => (
        <img
          src={src}
          alt=""
          loading={i === 0 ? 'eager' : 'lazy'}
          style={`animation-delay: ${i * 2}s`}
        />
      ))}
    </div>

    <div class="hero-inner container">
      <h1>
        Laurie<br />
        <span class="l2">Di Francesco</span>
      </h1>
      <hr class="horizon hero-horizon" />
      <p class="hero-tag">
        {t.heroLine1}<br />
        <em>{t.heroLine2}</em>
      </p>
    </div>

  </section>

  <!-- ─── Manifeste trilingue ───────────────────────────────── -->
  <section class="creed container" aria-label="Manifesto">
    <p class="creed-eyebrow">{t.creedEyebrow}</p>
    <div class="creed-lines">
      <p class="creed-it">Quando sono qui, non sono là.</p>
      <p class="creed-fr">Quand je suis ici, je ne suis pas là-bas.</p>
      <p class="creed-pt">Quando estou aqui, não estou lá.</p>
    </div>
  </section>

  <!-- ─── Aperçu des œuvres ─────────────────────────────────── -->
  <section class="works container" aria-label="Selected work">

    {t.projects.map((p, i) => (
      <>
        <a class="work-item" href={projectHrefs[i]}>
          <div class="work-frame">
            <img src={projectImages[i]} alt={projectTitles[i]} loading="lazy" />
          </div>
          <div class="work-meta">
            <span class="work-category">{p.category}</span>
            <h2 class="work-title">{projectTitles[i]}</h2>
            <p class="work-note">{p.note}</p>
            <span class="work-enter">{t.enter}</span>
          </div>
        </a>
        {i === 0 && (
          <div class="works-divider">
            <hr class="works-divider-line" />
            <p class="works-divider-label">{t.previousWorks}</p>
          </div>
        )}
      </>
    ))}

  </section>

</Layout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      });
    },
    { threshold: 0.15 }
  );
  document.querySelectorAll('.work-item').forEach(el => observer.observe(el));
</script>
