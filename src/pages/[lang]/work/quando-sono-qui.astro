---
import Layout from '../../../layouts/Layout.astro';
import '../../../styles/pages/work-project.css';
import { ui, type Lang } from '../../../i18n/translations';

export function getStaticPaths() {
  return [
    { params: { lang: 'fr' } },
    { params: { lang: 'it' } },
    { params: { lang: 'pt' } },
  ];
}

const { lang } = Astro.params;
const t = ui[lang as Lang];

const content = {
  fr: {
    plato: 'Et si on les forçait à monter une pente rude et escarpée, sans les lâcher avant de les avoir amenés à la pleine lumière du soleil, n\'en éprouveraient-ils pas douleur et gêne ? Et si, marchant vers le soleil, les yeux soudainement inondés de lumière éblouissante, pourraient-ils distinguer une seule des choses que nous appelons maintenant vraies réalités ?',
    platoSrc: 'Platon — République, Livre VII',
    char: 'La lucidité est la blessure la plus rapprochée du soleil.',
    charSrc: 'René Char — Feuillets d\'Hypnos (169)',
    projectText: 'Certains voyages ne se font pas de distance mais de présence divisée — cette impression d\'être toujours en partie ailleurs. <em>Quando sono qui, non sono là</em> trace cette géographie intérieure : portraits et paysages rassemblés à travers le Brésil, où la question de l\'appartenance s\'écrit dans les corps, les frontières et la lumière.',
    creditsLabel: 'Crédits',
    creditsText: "Image reproduite avec l'aimable autorisation de Tatila Lyma.",
  },
  it: {
    plato: 'E se qualcuno li costringesse a risalire un\'erta ripida e scabra senza lasciarli andare finché non li avesse portati alla piena luce del sole? Non proverrebbero dolore e disagio? E se camminassero verso il sole con gli occhi improvvisamente inondati di luce abbagliante, riuscirebbero a vedere anche una sola delle cose che ora chiamiamo vere realtà?',
    platoSrc: 'Platone — Repubblica, Libro VII',
    char: 'La lucidità è la ferita più vicina al sole.',
    charSrc: 'René Char — Feuillets d\'Hypnos (169)',
    creditsLabel: 'Crediti',
    creditsText: 'Immagine riprodotta per gentile concessione di Tatila Lyma.',
    projectText: 'Certi viaggi non si misurano di distanza, ma di presenza divisa — la sensazione di essere sempre in parte altrove. <em>Quando sono qui, non sono là</em> traccia quella geografia interiore: ritratti e paesaggi raccolti attraverso il Brasile, dove la questione dell\'appartenenza si scrive nei corpi, nelle frontiere e nella luce.',
  },
  pt: {
    plato: 'E se alguém os forçasse a subir uma encosta íngreme e áspera sem os soltar até tê-los levado à plena luz do sol? Não sentiriam dor e desconforto? E se caminhassem em direção ao sol com os olhos de repente inundados de luz brilhante, conseguiriam ver mesmo uma das coisas que agora chamamos de realidades verdadeiras?',
    platoSrc: 'Platão — República, Livro VII',
    char: 'A lucidez é a ferida mais próxima do sol.',
    charSrc: 'René Char — Feuillets d\'Hypnos (169)',
    projectText: 'Certas viagens não são feitas de distância, mas de presença dividida — a sensação de estar sempre em parte em outro lugar. <em>Quando sono qui, non sono là</em> traça essa geografia interior: retratos e paisagens reunidos pelo Brasil, onde a questão do pertencimento se escreve nos corpos, nas fronteiras e na luz.',
    creditsLabel: 'Créditos',
    creditsText: 'Imagem reproduzida com a gentil autorização de Tatila Lyma.',
  },
}[lang as 'fr' | 'it' | 'pt'];

const s = (file: string) => `/images/work/quando-sono-qui/${file}`;
type Photo = { src: string; n: number };
type Spread = { type: 'row' | 'single'; photos: Photo[] };
const p = (n: number): Photo => ({ src: s(`${n}.jpg`), n });

const spreads: Spread[] = [
  { type: 'row',    photos: [p(1), p(2)] },
  { type: 'row',    photos: [p(3), p(4), p(5)] },
  { type: 'single', photos: [p(6)] },
  { type: 'row',    photos: [p(7), p(8)] },
  { type: 'row',    photos: [p(9), p(10), p(11)] },
];
---

<Layout
  title="Quando sono qui, non sono là — Laurie Di Francesco"
  description="Quando sono qui, non sono là — An intimate geography of presence and absence. Brazil · ongoing."
  image="/images/work/quando-cover.jpg"
  lang={lang}
>

  <!-- ── Hero ──────────────────────────────────────────────── -->
  <section class="phero">
    <div class="phero-bg" aria-hidden="true">
      <img src="/images/work/quando-sono-qui/1.jpg" alt="" loading="eager" />
    </div>
    <div class="phero-inner container">
      <p class="phero-eyebrow">{t.home.projects[0].cerule}</p>
      <h1>Quando sono qui,<br /><strong>non sono là</strong></h1>
    </div>
  </section>

  <p class="phero-wip container">{t.home.creedEyebrow}</p>

  <!-- ── Ouverture 2 colonnes ──────────────────────────────── -->
  <section class="opening container">

    <!-- Colonne gauche : Platon + René Char -->
    <div class="opening-epi">

      <div class="epi-wrap">
        <blockquote class="epi-justify">{content.plato}</blockquote>
        <cite>{content.platoSrc}</cite>
      </div>
      <hr class="horizon epi-horizon" />

      <div class="epi-wrap">
        <blockquote>{content.char}</blockquote>
        <cite>{content.charSrc}</cite>
      </div>
      <hr class="horizon epi-horizon" />

    </div>

    <!-- Colonne droite : José Ramalho (toujours en PT) + texte du projet -->
    <div class="opening-proj">

      <div class="epi-wrap">
        <blockquote>
          A sombra que me move<br />
          Também me ilumina<br />
          Me leve nos cabelos<br />
          Me lave na piscina<br />
          Em cada ponto claro<br />
          Cometa que cai no mar<br />
          Em cada cor diferente<br />
          Que tente me clarear<br />
          É noite que vai chegar<br />
          É claro que é de manhã<br />
          É moça e anciã
        </blockquote>
        <cite>José Ramalho Neto — Galope Resante</cite>
      </div>
      <hr class="horizon epi-horizon" />

    </div>

  </section>

  <!-- ── Série photographique ──────────────────────────────── -->
  <div class="series">
    {spreads.map((spread) => (
      <div class={`spread spread--${spread.type} rv`}>
        {spread.photos.map((photo) => (
          <figure>
            <img
              src={photo.src}
              alt={`Quando sono qui, non sono là — ${photo.n}`}
              loading="lazy"
            />
          </figure>
        ))}
      </div>
    ))}
  </div>

  <!-- ── Crédits ─────────────────────────────────────────── -->
  <div class="project-credits">
    <div class="group">
      <div class="label">{content.creditsLabel}</div>
      <p>{content.creditsText}</p>
    </div>
  </div>

  <!-- ── Projet suivant ─────────────────────────────────────── -->
  <div class="next-project container">
    <span class="next-label">{t.work.nextProject}</span>
    <a href={`/${lang}/work/spilling-beyond-the-lines`}>{t.work.spillingTitle} →</a>
  </div>

</Layout>

<style is:global>
  .opening-proj { justify-content: flex-start; }
  .spread figure img { cursor: zoom-in; }
  .lb { position: fixed; inset: 0; background: rgba(20,32,43,.94); display: none; align-items: center; justify-content: center; z-index: 200; }
  .lb.open { display: flex; }
  .lb-photo { max-width: min(86vw, calc(100vw - 5.5rem)); max-height: 92vh; width: auto; height: auto; object-fit: contain; border-radius: 4px; display: block; }
  .lb-nav { position: absolute; top: 50%; transform: translateY(-50%); background: none; border: none; padding: 1rem .7rem; cursor: pointer; color: rgba(255,255,255,.45); transition: color .25s; line-height: 0; -webkit-tap-highlight-color: transparent; }
  .lb-nav:hover { color: rgba(255,255,255,.9); }
  .lb-nav svg { width: clamp(1.5rem, 3vw, 2.2rem); height: clamp(1.5rem, 3vw, 2.2rem); display: block; }
  .lb-prev { left: .5rem; }
  .lb-next { right: .5rem; }
</style>

<script>
  function justify() {
    const mob = window.innerWidth <= 700;
    document.querySelectorAll<HTMLElement>('.spread--row').forEach(row => {
      const figs = Array.from(row.querySelectorAll<HTMLElement>('figure'));
      const imgs = figs.map(f => f.querySelector('img') as HTMLImageElement);
      function apply() {
        if (mob) { figs.forEach(f => { f.style.flexGrow = ''; }); return; }
        imgs.forEach((im, i) => {
          const r = (im.naturalWidth && im.naturalHeight) ? im.naturalWidth / im.naturalHeight : 1;
          figs[i].style.flexGrow = r.toFixed(4);
        });
      }
      if (imgs.every(im => im.complete && im.naturalWidth)) apply();
      else imgs.forEach(im => im.addEventListener('load', apply));
    });
  }
  justify();
  window.addEventListener('resize', () => {
    clearTimeout((window as any)._jt);
    (window as any)._jt = setTimeout(justify, 150);
  });

  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('in'); obs.unobserve(e.target); }
    });
  }, { threshold: .06 });
  document.querySelectorAll('.rv').forEach(el => obs.observe(el));

  const lbAll = Array.from(document.querySelectorAll<HTMLImageElement>('.series img'));
  let lbIdx = 0;
  const lb = document.createElement('div');
  lb.className = 'lb';
  lb.innerHTML = `<button class="lb-nav lb-prev" aria-label="Previous"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg></button><img class="lb-photo" /><button class="lb-nav lb-next" aria-label="Next"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg></button>`;
  document.body.appendChild(lb);
  const lbPhoto = lb.querySelector<HTMLImageElement>('.lb-photo')!;
  const lbPrev = lb.querySelector<HTMLButtonElement>('.lb-prev')!;
  const lbNext = lb.querySelector<HTMLButtonElement>('.lb-next')!;
  function lbShow(i: number) {
    lbIdx = Math.max(0, Math.min(i, lbAll.length - 1));
    lbPhoto.src = lbAll[lbIdx].dataset.full || lbAll[lbIdx].src;
    lbPrev.style.opacity = lbIdx > 0 ? '1' : '0';
    lbPrev.style.pointerEvents = lbIdx > 0 ? 'auto' : 'none';
    lbNext.style.opacity = lbIdx < lbAll.length - 1 ? '1' : '0';
    lbNext.style.pointerEvents = lbIdx < lbAll.length - 1 ? 'auto' : 'none';
  }
  function lbClose() { lb.classList.remove('open'); document.body.style.overflow = ''; }
  lbAll.forEach((im, i) => im.addEventListener('click', () => { lbShow(i); lb.classList.add('open'); document.body.style.overflow = 'hidden'; }));
  lbPrev.addEventListener('click', e => { e.stopPropagation(); lbShow(lbIdx - 1); });
  lbNext.addEventListener('click', e => { e.stopPropagation(); lbShow(lbIdx + 1); });
  lb.addEventListener('click', e => { if (e.target === lb || e.target === lbPhoto) lbClose(); });
  document.addEventListener('keydown', e => {
    if (!lb.classList.contains('open')) return;
    if (e.key === 'Escape') lbClose();
    if (e.key === 'ArrowLeft') lbShow(lbIdx - 1);
    if (e.key === 'ArrowRight') lbShow(lbIdx + 1);
  });
  let lbTX = 0;
  lb.addEventListener('touchstart', e => { lbTX = (e as any).touches[0].clientX; }, { passive: true });
  lb.addEventListener('touchend', e => { const dx = lbTX - (e as any).changedTouches[0].clientX; if (Math.abs(dx) > 50) { dx > 0 ? lbShow(lbIdx + 1) : lbShow(lbIdx - 1); } });
</script>
