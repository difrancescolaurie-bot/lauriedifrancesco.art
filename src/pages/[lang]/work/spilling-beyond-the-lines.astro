---
import Layout from '../../../layouts/Layout.astro';
import '../../../styles/pages/work-project.css';
import { ui, type Lang } from '../../../i18n/translations';

export function getStaticPaths() {
  return [
    { params: { lang: 'fr' } },
    { params: { lang: 'it' } },
    { params: { lang: 'pt' } },
  ];
}

const { lang } = Astro.params;
const t = ui[lang as Lang];

const content = {
  fr: {
    p1: "Ce projet, d'abord conçu comme une exposition puis comme un livre de photographies, a émergé à la fin d'un chapitre de vie marqué par le déplacement. Il a été construit à partir d'archives personnelles — des images rassemblées sur plus de quinze ans, à travers plusieurs continents — moins le récit d'un voyage unique qu'une lente sédimentation de lieux, de rencontres et de lumière.",
    p2: "C'est dans ce contexte que la question des frontières s'est imposée avec force — limites visibles ou invisibles tracées entre les corps, les territoires et les récits. Ces images, portraits, végétaux, textures, structures, forment une cartographie sensible dans laquelle chaque photographie tente doucement de déplacer la perception.",
    cap1: "Ni tout à fait un départ ni vraiment un retour, mais une façon d'habiter les seuils, les passages, les plis d'une géographie intérieure.",
    cap2: "Déborder les lignes laisse trembler les contours, ouvrir l'espace, suspendre les certitudes.",
    cap3: "Pour moi, la photographie est une façon de rester en mouvement sans fuir, d'entrer en contact sans imposer — de capter ce <em>je-ne-sais-quoi</em> fugitif qui relie et révèle.",
    creditsLabel: 'Crédits',
    creditsText: "Images reproduites avec l'aimable autorisation de Diana Ferreira et Giovane Marquez.",
  },
  it: {
    p1: "Questo progetto, concepito dapprima come una mostra e poi come un libro fotografico, è emerso alla fine di un capitolo di vita segnato dallo spostamento. È stato costruito a partire da archivi personali, immagini scattate prima ancora di pensarmi fotografa, raccolte nel corso di più di quindici anni, attraverso diversi continenti: non tanto il resoconto di un singolo viaggio quanto una lenta sedimentazione di luoghi, incontri e luce.",
    p2: "È in questo contesto che la questione dei confini si è imposta con forza: limiti visibili o invisibili tracciati tra i corpi, i territori e le narrazioni. Queste immagini, ritratti, vegetazione, texture, strutture, formano una cartografia sensibile in cui ogni fotografia tenta dolcemente di spostare la percezione.",
    cap1: "Non proprio una partenza né davvero un ritorno, ma un modo di abitare le soglie, i passaggi, le pieghe di una geografia interiore",
    cap2: "Attraversare lascia tremare i contorni",
    cap3: "Per me, la fotografia è un modo di rimanere in movimento senza fuggire, di entrare in contatto senza imporre: di cogliere quel fuggitivo <em>je-ne-sais-quoi</em> che connette e rivela.",
    creditsLabel: 'Crediti',
    creditsText: "Immagini riprodotte per gentile concessione di Diana Ferreira e Giovane Marquez.",
  },
  pt: {
    p1: "Este projeto, inicialmente concebido como uma exposição e depois como um livro fotográfico, emergiu ao fim de um capítulo de vida marcado pelo deslocamento. Foi construído a partir de arquivos pessoais — imagens reunidas ao longo de mais de quinze anos, em vários continentes — menos o registro de uma única jornada do que uma lenta sedimentação de lugares, encontros e luz.",
    p2: "Foi nesse contexto que a questão das fronteiras se impôs com força — fronteiras visíveis ou invisíveis traçadas entre corpos, territórios e narrativas. Essas imagens, retratos, vegetação, texturas, estruturas, formam uma cartografia sensível em que cada fotografia tenta suavemente deslocar a percepção.",
    cap1: "Nem bem uma partida nem realmente um retorno, mas uma forma de habitar os limiares, as passagens, as dobras de uma geografia interior.",
    cap2: "Transbordar das linhas deixa os contornos tremer, o espaço abrir-se, as certezas suspenderem-se.",
    cap3: "Para mim, a fotografia é uma forma de permanecer em movimento sem fugir, de entrar em contato sem impor — de capturar aquele fugidio <em>je-ne-sais-quoi</em> que conecta e revela.",
    creditsLabel: 'Créditos',
    creditsText: 'Imagens reproduzidas com a gentil autorização de Diana Ferreira e Giovane Marquez.',
  },
}[lang as 'fr' | 'it' | 'pt'];

const SQ = 'https://images.squarespace-cdn.com/content/v1/5fa6cb9fbca79b7a7020b762';
const s = (path: string) => `/images/spilling/${path}`;

type Photo = { src: string; full: string; n: number; figClass?: string };
type Spread = {
  type: 'row' | 'single' | 'composed';
  photos: Photo[];
  caption?: string;
  captionStyle?: 'prose';
};

const local = (file: string, n: number, figClass?: string): Photo => ({
  src: s(file), full: s(file), n, ...(figClass && { figClass })
});

const spreads: Spread[] = [
  { type: 'row', photos: [local('1.jpg',1), local('2.jpg',2)] },
  { type: 'row', photos: [local('3.jpg',3), local('4.jpg',4), local('5.jpg',5), local('6.jpg',6)] },
  { type: 'row', photos: [local('7.jpg',7), local('8.jpg',8), local('9.jpg',9), local('10.jpg',10)], caption: content.cap1, captionStyle: 'title' },
  { type: 'composed', photos: [local('11.jpg',11), local('12.jpg',12), local('13.jpg',13)] },
  { type: 'row', photos: [local('14.jpg',14), local('15.jpg',15), local('16.jpg',16), local('17.jpg',17)] },
  { type: 'row', photos: [local('18.jpg',18), local('19.jpg',19), local('20.jpg',20), local('21.jpg',21,'port-crop')] },
  { type: 'row', photos: [local('22.jpg',22), local('23.jpg',23)] },
  { type: 'row', photos: [local('24.jpg',24), local('25.jpg',25)] },
  { type: 'row', photos: [local('26.jpg',26), local('27.jpg',27), local('28.jpg',28), local('29.jpg',29)] },
  { type: 'single', photos: [local('30.jpg',30)], caption: content.cap2, captionStyle: 'title' },
  { type: 'row', photos: [local('31.jpg',31), local('32.jpg',32), local('33.jpg',33), local('34.jpg',34)] },
  { type: 'row', photos: [local('35.jpg',35), local('36.jpg',36), local('37.jpg',37), local('38.jpg',38)] },
  { type: 'single', photos: [local('39.jpg',39)] },
  { type: 'row', photos: [local('40.jpg',40), local('41.jpg',41)] },
  { type: 'row', photos: [local('42.jpg',42), local('43.jpg',43)] },
  { type: 'row', photos: [local('45.jpg',45), local('46.jpg',46)], caption: content.cap3, captionStyle: 'title' },
  { type: 'single', photos: [local('47.jpg',47,'land-crop')] },
  { type: 'single', photos: [local('48.jpg',48,'land-crop')] },
];
---

<Layout
  title={`${t.work.spillingTitle} — Laurie Di Francesco`}
  description="A photobook born from displacement and the question of borders — Belo Horizonte, Brazil, 2024."
  image="/images/work/spilling-cover.jpg"
  lang={lang}
>

  <!-- ── Hero ─────────────────────────────────────────────── -->
  <section class="phero">
    <div class="phero-bg" aria-hidden="true">
      <img src={`${SQ}/5990bdbc-6934-4b56-83f4-dbf6b482b858/Tapajos+ok.jpg?format=2000w`} alt="" loading="eager" />
    </div>
    <div class="phero-inner container">
      <p class="phero-eyebrow">{t.home.projects[1].cerule}</p>
      <h1>{t.work.spillingTitle}</h1>
    </div>
  </section>

  <!-- ── Intro ─────────────────────────────────────────────── -->
  <section class="intro">

    <div class="intro-epi">
      <div class="epi-wrap">
        <blockquote>
          Por algum tempo<br />
          Que afinal passou depressa, como tudo tem de passar<br />
          Hoje eu me sinto<br />
          Como se ter ido fosse necessário para voltar<br />
          Tanto mais vivo<br />
          De vida mais vivida, dividida pra lá e pra cá
        </blockquote>
        <cite>Gilberto Gil — Back in Bahia</cite>
      </div>
      <hr class="horizon spilling-horizon" />
    </div>

    <div class="intro-proj">
      <p class="opening-eyebrow">{t.work.theProject}</p>
      <p class="intro-text">{content.p1}</p>
      <p class="intro-text">{content.p2}</p>
      <hr class="horizon intro-proj-horizon" />
    </div>

  </section>

  <!-- ── Série photographique ──────────────────────────────── -->
  <div class="series">
    {spreads.map((spread) => (
      <>
        <div class={`spread spread--${spread.type} rv`}>
          {spread.photos.map((photo) => (
            <figure class={photo.figClass}>
              <img
                src={photo.src}
                data-full={photo.full}
                alt={`${t.work.spillingTitle} — photo ${photo.n}`}
                loading="lazy"
              />
            </figure>
          ))}
        </div>
        {spread.caption && (
          <p class={`series-caption${spread.captionStyle === 'prose' ? ' series-caption--prose' : ''} rv`} set:html={spread.caption} />
        )}
      </>
    ))}
  </div>

  <!-- ── Crédits ─────────────────────────────────────────── -->
  <div class="project-credits">
    <div class="group">
      <div class="label">{content.creditsLabel}</div>
      <p>{content.creditsText}</p>
    </div>
  </div>

  <!-- ── Projet suivant ─────────────────────────────────────── -->
  <div class="next-project container">
    <span class="next-label">{t.work.nextProject}</span>
    <a href={`/${lang}/work/toward-the-blue`}>Toward the Blue →</a>
  </div>

</Layout>

<style is:global>
  .spread figure img { cursor: zoom-in; }

  figure.land-crop {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    position: relative;
  }
  figure.land-crop img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  figure.port-crop {
    aspect-ratio: 2 / 3;
    overflow: hidden;
    position: relative;
  }
  figure.port-crop img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 90% center;
  }

  .spread--composed {
    align-items: flex-start;
    justify-content: center;
    gap: 0;
    margin-block: clamp(10rem, 18vh, 14rem) clamp(6rem, 10vh, 8rem) !important;
  }
  .spread--composed figure { flex: 0 1 34%; }
  .spread--composed figure:nth-child(1) { transform: translateY(-20%); z-index: 2; margin-right: -7%; }
  .spread--composed figure:nth-child(2) { transform: translateY(0); z-index: 3; }
  .spread--composed figure:nth-child(3) { transform: translateY(8%); z-index: 1; margin-left: -5%; }
  .spread--composed img { border-radius: 12px; }

  .lb { position: fixed; inset: 0; background: rgba(20,32,43,.94); display: none; align-items: center; justify-content: center; z-index: 200; }
  .lb.open { display: flex; }
  .lb-photo { max-width: min(86vw, calc(100vw - 5.5rem)); max-height: 92vh; width: auto; height: auto; object-fit: contain; border-radius: 4px; display: block; }
  .lb-nav { position: absolute; top: 50%; transform: translateY(-50%); background: none; border: none; padding: 1rem .7rem; cursor: pointer; color: rgba(255,255,255,.45); transition: color .25s; line-height: 0; -webkit-tap-highlight-color: transparent; }
  .lb-nav:hover { color: rgba(255,255,255,.9); }
  .lb-nav svg { width: clamp(1.5rem, 3vw, 2.2rem); height: clamp(1.5rem, 3vw, 2.2rem); display: block; }
  .lb-prev { left: .5rem; }
  .lb-next { right: .5rem; }

  @media (max-width: 700px) {
    .spread--composed {
      flex-wrap: nowrap !important; gap: 0 !important; margin-bottom: 5rem !important;
    }
    .spread--composed figure { flex: 0 1 38% !important; width: auto !important; transform: none !important; }
    .spread--composed figure:nth-child(1) { transform: translateY(0) !important; z-index: 2 !important; margin: 0 -7% 0 0 !important; }
    .spread--composed figure:nth-child(2) { transform: translateY(0) !important; z-index: 3 !important; margin: 0 !important; }
    .spread--composed figure:nth-child(3) { transform: translateY(6%) !important; z-index: 1 !important; margin: 0 0 0 -5% !important; }
    .spread .land { width: 100% !important; }
  }
</style>

<script>
  function justify() {
    const mob = window.innerWidth <= 700;
    document.querySelectorAll<HTMLElement>('.spread--row').forEach(row => {
      const figs = Array.from(row.querySelectorAll<HTMLElement>('figure'));
      const imgs = figs.map(f => f.querySelector('img') as HTMLImageElement);
      function apply() {
        if (mob) { figs.forEach(f => { f.style.flexGrow = ''; }); return; }
        const asp = imgs.map((im, i) => {
          if (figs[i].classList.contains('land-crop')) return 3 / 2;
          if (figs[i].classList.contains('port-crop')) return 2 / 3;
          return (im.naturalWidth && im.naturalHeight) ? im.naturalWidth / im.naturalHeight : 1;
        });
        figs.forEach((f, i) => { f.style.flexGrow = asp[i].toFixed(4); });
      }
      if (imgs.every(im => im.complete && im.naturalWidth)) apply();
      else imgs.forEach(im => im.addEventListener('load', apply));
    });
  }
  justify();
  window.addEventListener('resize', () => { clearTimeout((window as any)._jt); (window as any)._jt = setTimeout(justify, 150); });

  function tagLandscape() {
    if (window.innerWidth > 700) return;
    const imgs = Array.from(document.querySelectorAll<HTMLImageElement>('.spread--row figure img'));
    let remaining = imgs.filter(img => !img.complete || !img.naturalWidth).length;
    imgs.forEach(img => {
      function mark() {
        if (img.naturalWidth && img.naturalHeight && img.naturalWidth / img.naturalHeight > 1.4)
          img.closest('figure')!.classList.add('land');
      }
      if (img.complete && img.naturalWidth) mark();
      else {
        img.addEventListener('load', () => { mark(); if (--remaining <= 0) reorgMobile(); }, { once: true });
        img.addEventListener('error', () => { if (--remaining <= 0) reorgMobile(); }, { once: true });
      }
    });
    if (remaining <= 0) reorgMobile();
  }

  function reorgMobile() {
    if (window.innerWidth > 700) return;
    document.querySelectorAll<HTMLElement>('.spread--row').forEach(spread => {
      const figs = Array.from(spread.querySelectorAll<HTMLElement>(':scope > figure'));
      const lands = figs.filter(f => f.classList.contains('land'));
      const ports = figs.filter(f => !f.classList.contains('land'));
      if (!lands.length || !ports.length) return;
      const parent = spread.parentElement!;
      const anchor = spread.nextSibling;
      figs.forEach(f => spread.removeChild(f));
      ports.forEach(f => spread.appendChild(f));
      let ins = anchor;
      lands.forEach(f => {
        const row = document.createElement('div');
        row.className = 'spread spread--row in';
        row.appendChild(f);
        parent.insertBefore(row, ins);
        ins = row.nextSibling;
      });
    });
  }

  tagLandscape();
  window.addEventListener('resize', () => {
    clearTimeout((window as any)._lt);
    (window as any)._lt = setTimeout(() => {
      document.querySelectorAll('.spread figure').forEach(f => f.classList.remove('land'));
      tagLandscape();
    }, 150);
  });

  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); obs.unobserve(e.target); } });
  }, { threshold: .06 });
  document.querySelectorAll('.rv').forEach(el => obs.observe(el));

  const lbAll = Array.from(document.querySelectorAll<HTMLImageElement>('.series img'));
  let lbIdx = 0;
  const lb = document.createElement('div');
  lb.className = 'lb';
  lb.innerHTML = `<button class="lb-nav lb-prev" aria-label="Previous"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg></button><img class="lb-photo" /><button class="lb-nav lb-next" aria-label="Next"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg></button>`;
  document.body.appendChild(lb);
  const lbPhoto = lb.querySelector<HTMLImageElement>('.lb-photo')!;
  const lbPrev = lb.querySelector<HTMLButtonElement>('.lb-prev')!;
  const lbNext = lb.querySelector<HTMLButtonElement>('.lb-next')!;
  function lbShow(i: number) {
    lbIdx = Math.max(0, Math.min(i, lbAll.length - 1));
    lbPhoto.src = lbAll[lbIdx].dataset.full || lbAll[lbIdx].src;
    lbPrev.style.opacity = lbIdx > 0 ? '1' : '0';
    lbPrev.style.pointerEvents = lbIdx > 0 ? 'auto' : 'none';
    lbNext.style.opacity = lbIdx < lbAll.length - 1 ? '1' : '0';
    lbNext.style.pointerEvents = lbIdx < lbAll.length - 1 ? 'auto' : 'none';
  }
  function lbClose() { lb.classList.remove('open'); document.body.style.overflow = ''; }
  lbAll.forEach((im, i) => im.addEventListener('click', () => { lbShow(i); lb.classList.add('open'); document.body.style.overflow = 'hidden'; }));
  lbPrev.addEventListener('click', e => { e.stopPropagation(); lbShow(lbIdx - 1); });
  lbNext.addEventListener('click', e => { e.stopPropagation(); lbShow(lbIdx + 1); });
  lb.addEventListener('click', e => { if (e.target === lb || e.target === lbPhoto) lbClose(); });
  document.addEventListener('keydown', e => {
    if (!lb.classList.contains('open')) return;
    if (e.key === 'Escape') lbClose();
    if (e.key === 'ArrowLeft') lbShow(lbIdx - 1);
    if (e.key === 'ArrowRight') lbShow(lbIdx + 1);
  });
  let lbTX = 0;
  lb.addEventListener('touchstart', e => { lbTX = (e as any).touches[0].clientX; }, { passive: true });
  lb.addEventListener('touchend', e => { const dx = lbTX - (e as any).changedTouches[0].clientX; if (Math.abs(dx) > 50) { dx > 0 ? lbShow(lbIdx + 1) : lbShow(lbIdx - 1); } });
</script>
