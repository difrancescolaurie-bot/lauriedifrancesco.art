---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page introuvable — Laurie Di Francesco"
  description="Cette page n'existe pas."
>
  <section class="nf">
    <div class="nf-bg" aria-hidden="true">
      <img src="/images/work/toward-the-blue/Slovenia_5.JPG" alt="" loading="eager" />
    </div>
    <div class="nf-content container">
      <span class="nf-code" aria-hidden="true">404</span>
      <h1 class="nf-title">Cette page<br /><strong>s'est égarée</strong></h1>
      <p class="nf-sub">Elle n'existe pas ou a été déplacée.</p>
      <a href="/" class="nf-back">← Retour à l'accueil</a>
    </div>
  </section>
</Layout>

<style is:global>
  .nf {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .nf-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .nf-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .nf-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(20,32,43,.88) 0%, rgba(20,32,43,.45) 100%);
  }

  .nf-content {
    position: relative;
    z-index: 1;
    color: #fff;
    padding-block: clamp(6rem, 15vh, 10rem);
  }

  .nf-code {
    display: block;
    font-family: var(--font-title);
    font-weight: 200;
    font-size: clamp(7rem, 22vw, 16rem);
    line-height: .85;
    color: rgba(255,255,255,.1);
    letter-spacing: -.02em;
    margin-bottom: .5rem;
    user-select: none;
  }

  .nf-title {
    font-family: var(--font-title);
    font-weight: 300;
    font-size: clamp(1.6rem, 4.5vw, 3.2rem);
    text-transform: uppercase;
    letter-spacing: clamp(.06em, .8vw, .14em);
    line-height: 1.05;
    color: #fff;
    margin-bottom: 2rem;
  }

  .nf-title strong { font-weight: 500; }

  .nf-sub {
    font-family: var(--font-body);
    font-size: clamp(.82rem, 1.1vw, .92rem);
    color: rgba(255,255,255,.55);
    letter-spacing: .06em;
    margin-bottom: 3rem;
  }

  .nf-back {
    display: inline-block;
    font-family: var(--font-body);
    font-size: .72rem;
    text-transform: uppercase;
    letter-spacing: .18em;
    color: rgba(255,255,255,.85);
    border-bottom: 1px solid rgba(255,255,255,.35);
    padding-bottom: 3px;
    transition: color .25s, border-color .25s;
  }

  .nf-back:hover {
    color: #fff;
    border-color: rgba(255,255,255,.85);
  }
</style>
