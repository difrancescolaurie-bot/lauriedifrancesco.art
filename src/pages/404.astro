---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page introuvable — Laurie Di Francesco"
  description="Cette page n'existe pas."
>
  <div class="not-found container">
    <p class="nf-code">404</p>
    <h1 class="nf-title">Page introuvable</h1>
    <hr class="horizon nf-horizon" />
    <p class="nf-text">Cette page n'existe pas ou a été déplacée.</p>
    <a href="/" class="nf-link">← Retour à l'accueil</a>
  </div>
</Layout>

<style is:global>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding-top: clamp(8rem, 20vh, 14rem);
    padding-bottom: clamp(8rem, 20vh, 14rem);
    min-height: 70vh;
  }

  .nf-code {
    font-family: var(--font-title);
    font-weight: 300;
    font-size: clamp(4rem, 14vw, 10rem);
    color: var(--brume);
    line-height: 1;
    margin-bottom: .5rem;
  }

  .nf-title {
    font-family: var(--font-title);
    font-weight: 300;
    font-size: clamp(1.4rem, 3vw, 2.2rem);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--encre);
    margin-bottom: 1.8rem;
  }

  .nf-horizon {
    margin-bottom: 1.8rem;
  }

  .nf-text {
    font-size: clamp(.9rem, 1.3vw, 1rem);
    color: var(--ardoise);
    margin-bottom: 2.5rem;
  }

  .nf-link {
    font-family: var(--font-body);
    font-size: .72rem;
    text-transform: uppercase;
    letter-spacing: .16em;
    color: var(--cerule);
    border-bottom: 1px solid var(--cerule);
    padding-bottom: 2px;
    transition: opacity .25s;
  }

  .nf-link:hover { opacity: .65; }
</style>
