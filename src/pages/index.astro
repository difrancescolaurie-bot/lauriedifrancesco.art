---
import Layout from '../layouts/Layout.astro';
import '../styles/pages/home.css';

const heroImages = [
  '/images/hero/hero-2.jpg',
  '/images/hero/hero-3.jpg',
  '/images/hero/hero-4.jpg',
  '/images/hero/hero-1.jpg',
];

const projects = [
  {
    href: '/work/quando-sono-qui',
    category: 'Brazil · ongoing',
    title: 'Quando sono qui, non sono là',
    cerule: 'Resignifying',
    note: 'Being there means missing here. Or does it?',
    image: '/images/work/quando-cover.jpg',
  },
  {
    href: '/work/spilling-beyond-the-lines',
    category: '',
    title: 'Spilling Beyond the Lines',
    cerule: 'Do lines truly divide?',
    note: 'When the free profusion of forms around us, and another\'s gaze, rewrote my own: a work born of a rupture that draws us closer.',
    image: '/images/work/spilling-cover.jpg',
  },
  {
    href: '/work/toward-the-blue',
    category: 'Water & sky',
    title: 'Toward the Blue',
    cerule: 'Sky-blue in her eyes',
    note: 'Look up into the blue of the sky. Dream of a lightness lost, or never known.',
    image: '/images/work/toward-the-blue-cover.jpg',
  },
  {
    href: '/work/vedere-venezia',
    category: 'Venice',
    title: 'Vedere Venezia e Non Morire',
    cerule: 'Rebirth. An attempt.',
    note: 'To hold on. To let go. To exist in one\'s own gaze.',
    image: '/images/work/vedere-venezia-cover.jpg',
  },
  {
    href: '/work/en-corps-en-la-mer',
    category: 'Sea & body',
    title: 'En Corps à la Mer',
    cerule: 'Surfacing',
    note: 'Learning to walk again, through water and through dreams.',
    image: '/images/work/en-corps-cover.jpg',
  },
];
---

<Layout
  title="Home"
  description="Documentary and poetic photography · Where the blue of the sky opens into new shades"
>

  <!-- ─── Hero ─────────────────────────────────────────────── -->
  <section class="hero" aria-label="Hero">

    <div class="hero-bg" aria-hidden="true">
      {heroImages.map((src, i) => (
        <img
          src={src}
          alt=""
          loading={i === 0 ? 'eager' : 'lazy'}
          style={`animation-delay: ${i * 2}s`}
        />
      ))}
    </div>

    <div class="hero-inner container">
      <h1>
        Laurie<br />
        <span class="l2">Di Francesco</span>
      </h1>
      <hr class="horizon hero-horizon" />
      <p class="hero-tag">
        Documentary and poetic photography<br />
        <em>Where the blue of the sky opens into new shades</em>
      </p>
    </div>

  </section>

  <!-- ─── Manifeste trilingue ───────────────────────────────── -->
  <section class="creed container" aria-label="Manifesto">
    <p class="creed-eyebrow">Work in progress</p>
    <div class="creed-lines">
      <p class="creed-it">Quando sono qui, non sono là.</p>
      <p class="creed-fr">Quand je suis ici, je ne suis pas là-bas.</p>
      <p class="creed-pt">Quando estou aqui, não estou lá.</p>
    </div>
  </section>

  <!-- ─── Aperçu des œuvres ─────────────────────────────────── -->
  <section class="works container" aria-label="Selected work">

    {projects.map((p, i) => (
      <>
        <a class="work-item" href={p.href}>
          <div class="work-frame">
            {p.image
              ? <img src={p.image} alt={p.title} loading="lazy" />
              : <span class="work-placeholder-label">{p.title}</span>
            }
          </div>
          <div class="work-meta">
            <span class="work-category">{p.cerule}</span>
            <h2 class="work-title">{p.title}</h2>
            <p class="work-note">{p.note}</p>
            <span class="work-enter">Enter ↗</span>
          </div>
        </a>
        {i === 0 && (
          <div class="works-divider">
            <hr class="works-divider-line" />
            <p class="works-divider-label">Previous works</p>
          </div>
        )}
      </>
    ))}

  </section>

</Layout>


<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      });
    },
    { threshold: 0.15 }
  );
  document.querySelectorAll('.work-item').forEach(el => observer.observe(el));
</script>
