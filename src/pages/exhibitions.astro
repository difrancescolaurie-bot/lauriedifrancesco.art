---
import Layout from '../layouts/Layout.astro';
import '../styles/pages/exhibitions.css';

const installationImages = [
  { src: '/images/exhibitions/PXL_20240724_155308369.MP.jpg', cropLeft: true },
  { src: '/images/exhibitions/PXL_20240720_030301485.MP.jpg' },
  { src: '/images/exhibitions/PXL_20240720_030314191.MP~3.jpg' },
  { src: '/images/exhibitions/PXL_20240724_183757430.MP~2.jpg' },
  { src: '/images/exhibitions/PXL_20240720_145949249.MP~2.jpg' },
  { src: '/images/exhibitions/PXL_20240725_153125868.MP.jpg' },
  { src: '/images/exhibitions/PXL_20240725_153225295.jpg' },
  { src: '/images/exhibitions/PXL_20240727_160503711.MP.jpg' },
  { src: '/images/exhibitions/PXL_20240714_152904533.MP.jpg' },
  { src: '/images/exhibitions/WhatsApp Image 2026-06-24 at 11.09.25.jpg' },
];

const videos = [
  { src: '/videos/loop-print.mp4',  label: 'Printing' },
  { src: '/videos/loop-frame.mp4',  label: 'Framing' },
  { src: '/videos/loop-mount.mp4',  label: 'Mounting' },
];
---

<Layout
  title="Exhibitions"
  description="Spilling Beyond the Lines — First solo exhibition, Livraria da Rua, Belo Horizonte, Brazil, July 2024."
>

  <!-- ── Titre ──────────────────────────────────────────────── -->
  <section class="ex-head container">
    <p class="ex-eyebrow">Exhibitions</p>
    <h1 class="ex-h1">Spilling Beyond the Lines</h1>
    <p class="ex-meta">
      <span class="ex-meta-accent">First solo exhibition</span>
      &nbsp;·&nbsp; Livraria da Rua — Belo Horizonte, Brazil
      &nbsp;·&nbsp; July 2024
      &nbsp;·&nbsp; Twenty-five photographs
    </p>
    <hr class="horizon ex-horizon" />
  </section>

  <!-- ── Bloc œuvre + collectionneurs ──────────────────────── -->
  <div class="ex-artwork-wrap rv in">
    <div class="ex-artwork-pair" id="artwork-pair">
      <figure class="ex-artwork-fig" id="fig-artwork">
        <img
          src="/images/exhibitions/artwork.jpg"
          alt="Crianças no parque brincando nos chafarizes"
          loading="eager"
          class="ex-artwork-img"
        />
      </figure>
      <figure class="ex-artwork-fig" id="fig-collectors">
        <img
          src="/images/exhibitions/WhatsApp Image 2026-06-24 at 11.26.44.jpg"
          alt="Collectors with the work"
          loading="eager"
          class="ex-artwork-img"
        />
      </figure>
    </div>

    <div class="ex-artwork-caption">
      <div class="ex-artwork-title-block">
        <span class="ex-artwork-border"></span>
        <div>
          <p class="ex-artwork-title-pt">Crianças no parque brincando nos chafarizes</p>
          <p class="ex-artwork-title-en">Children playing in the park fountains</p>
          <p class="ex-artwork-tech">Paris, 2010 · analogue camera</p>
          <p class="ex-artwork-status">Acquired in a private collection.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Texte d'intro ─────────────────────────────────────── -->
  <div class="ex-intro rv">
    <p class="ex-intro-label">The exhibition</p>
    <p class="ex-intro-text">
      The work that became <em>Spilling Beyond the Lines</em> was first shown here,
      in a solo exhibition of twenty-five photographs built around a single question:
      what a border truly separates. Portraits and landscapes hung in counterpoint —
      faces and places gathered across continents, each one singular, set side by side
      until they began to answer one another. The series has since been carried further,
      and completed, as the project shown on this site.
    </p>
    <a class="ex-link" href="/work/spilling-beyond-the-lines">
      View the project — Spilling Beyond the Lines →
    </a>
  </div>

  <!-- ── Grille vues d'accrochage ──────────────────────────── -->
  <div class="ex-grid-wrap">

    <!-- Rangée 1 : 3 photos -->
    <div class="ex-grid-row">
      <figure class="ex-grid-fig">
        <img src="/images/exhibitions/1.jpg" alt="" loading="lazy" class="ex-grid-img" />
      </figure>
      <figure class="ex-grid-fig">
        <img src="/images/exhibitions/2.jpg" alt="" loading="lazy" class="ex-grid-img" />
      </figure>
      <figure class="ex-grid-fig">
        <img src="/images/exhibitions/3.jpg" alt="" loading="lazy" class="ex-grid-img" />
      </figure>
    </div>

    <!-- Rangée 2 : 3 photos -->
    <div class="ex-grid-row">
      <figure class="ex-grid-fig">
        <img src="/images/exhibitions/4.jpg" alt="" loading="lazy" class="ex-grid-img" />
      </figure>
      <figure class="ex-grid-fig">
        <img src="/images/exhibitions/5.jpg" alt="" loading="lazy" class="ex-grid-img" />
      </figure>
      <figure class="ex-grid-fig">
        <img src="/images/exhibitions/6.jpg" alt="" loading="lazy" class="ex-grid-img" />
      </figure>
    </div>

    <!-- Rangée 3 : 4 photos -->
    <div class="ex-grid-row">
      <figure class="ex-grid-fig">
        <img src="/images/exhibitions/7.jpg" alt="" loading="lazy" class="ex-grid-img" />
      </figure>
      <figure class="ex-grid-fig">
        <img src="/images/exhibitions/8.jpg" alt="" loading="lazy" class="ex-grid-img" />
      </figure>
      <figure class="ex-grid-fig">
        <img src="/images/exhibitions/10.jpg" alt="" loading="lazy" class="ex-grid-img" />
      </figure>
      <figure class="ex-grid-fig">
        <img src="/images/exhibitions/11.jpg" alt="" loading="lazy" class="ex-grid-img" />
      </figure>
    </div>

  </div>

  <!-- ── Impression / Encadrement / Montage ────────────────── -->
  <div class="ex-craft">
    <p class="ex-craft-eyebrow">Printing, framing &amp; mounting</p>
    <p class="ex-craft-sub">The craft behind the show</p>

    <div class="ex-videos">

      <div class="ex-video-col">
        <video src="/videos/loop-print.mp4" autoplay muted loop playsinline class="ex-video"></video>
        <p class="ex-video-label">Printing</p>
        <p class="ex-video-title">Studio Artmosphere</p>
        <p class="ex-credit-detail">· Archival pigment print on Hahnemühle Studio Enhanced 210 gsm<br />· Canon image PROGRAF PRO-6000<br />· LUCIA PRO pigment inks<br />· Artmosphere colour profile.</p>
      </div>

      <div class="ex-video-col">
        <video src="/videos/loop-frame.mp4" autoplay muted loop playsinline class="ex-video"></video>
        <p class="ex-video-label">Framing</p>
        <p class="ex-video-title">Atelier Baumecker</p>
        <p class="ex-credit-detail">· Conservation framing in treated and sealed Brazilian natural wood.<br />· Neutral foamboard mount with neutral adhesives and/or neutral passe-partout.</p>
      </div>

      <div class="ex-video-col">
        <video src="/videos/loop-mount.mp4" autoplay muted loop playsinline class="ex-video"></video>
        <p class="ex-video-label">Mounting</p>
        <p class="ex-video-title">Jackson Cardoso</p>
        <p class="ex-credit-detail">· From Albuquerque Contemporânea Art Gallery, Belo Horizonte.</p>
      </div>

    </div>
  </div>

  <!-- ── Remerciements ─────────────────────────────────────── -->
  <div class="ex-thanks rv">
    <p class="ex-thanks-label">Acknowledgements</p>
    <p class="ex-thanks-text">
      Special thanks to <strong class="ex-thanks-name">Mathilde</strong>, <strong class="ex-thanks-name">Gautier</strong>, <strong class="ex-thanks-name">Zé</strong>, <strong class="ex-thanks-name">Soraia</strong>, <strong class="ex-thanks-name">Rafa</strong>, <strong class="ex-thanks-name">Marie-Françoise</strong>, <strong class="ex-thanks-name">Ulisses</strong>, <strong class="ex-thanks-name">Verônica</strong>, <strong class="ex-thanks-name">Paulo</strong> and <strong class="ex-thanks-name">Cris</strong>, for their precious support and encouragement throughout this project. Thank you to <strong class="ex-thanks-name">Rodrigo</strong> from <strong class="ex-thanks-name">Studio Artmosphere</strong>, <strong class="ex-thanks-name">Hugo</strong> from <strong class="ex-thanks-name">Atelier Baumecker</strong> and <strong class="ex-thanks-name">Jackson Cardoso</strong> for their remarkable work and professionalism. And thank you to every friend who came to the opening — your presence was deeply moving. I owe you all so much. May the adventure continue.
    </p>
  </div>

</Layout>


<script>
  /* ── Justified grid rows (natural aspect ratios) ────── */
  function justifyGrid() {
    document.querySelectorAll<HTMLElement>('.ex-grid-row').forEach(row => {
      const figs = Array.from(row.querySelectorAll<HTMLElement>('.ex-grid-fig'));
      const imgs = figs.map(f => f.querySelector('img') as HTMLImageElement);
      function apply() {
        imgs.forEach((im, i) => {
          const ratio = (im.naturalWidth && im.naturalHeight)
            ? im.naturalWidth / im.naturalHeight : 1;
          figs[i].style.flexGrow = ratio.toFixed(4);
        });
      }
      if (imgs.every(im => im.complete && im.naturalWidth)) apply();
      else imgs.forEach(im => im.addEventListener('load', apply));
    });
  }
  justifyGrid();
  window.addEventListener('resize', () => {
    clearTimeout((window as any)._jg);
    (window as any)._jg = setTimeout(justifyGrid, 150);
  });

  /* ── Justified artwork pair ─────────────────────────── */
  function justifyArtwork() {
    const pair = document.getElementById('artwork-pair');
    if (!pair) return;
    const figs = Array.from(pair.querySelectorAll('.ex-artwork-fig'));
    const imgs = figs.map(f => f.querySelector('img') as HTMLImageElement);

    function apply() {
      imgs.forEach((img, i) => {
        if (img.naturalWidth && img.naturalHeight) {
          figs[i].style.flexGrow = (img.naturalWidth / img.naturalHeight).toFixed(4);
        }
      });
    }

    let pending = imgs.filter(img => !img.complete || !img.naturalWidth).length;
    if (pending === 0) { apply(); return; }
    imgs.forEach(img => {
      if (!img.complete || !img.naturalWidth) {
        img.addEventListener('load', () => { if (--pending <= 0) apply(); }, { once: true });
        img.addEventListener('error', () => { if (--pending <= 0) apply(); }, { once: true });
      }
    });
  }

  /* ── Scroll reveal ──────────────────────────────────── */
  const observer = new IntersectionObserver(
    entries => entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('in'); observer.unobserve(e.target); }
    }),
    { threshold: 0.08 }
  );
  document.querySelectorAll('.rv').forEach(el => observer.observe(el));

  justifyArtwork();
</script>
