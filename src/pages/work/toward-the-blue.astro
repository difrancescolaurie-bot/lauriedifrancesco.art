---
import Layout from '../../layouts/Layout.astro';

const files: Record<number, string> = {
  1:  'Slovenia_1.JPG',
  2:  'Slovenia_2.JPG',
  3:  'Slovenia_3.JPG',
  4:  'Slovenia_4.JPG',
  5:  'Slovenia_5.JPG',
  6:  'Slovenia_6.jpg',
  7:  'Slovenia_7.JPG',
  8:  'Slovenia_8.jpg',
  9:  'Slovenia_9.JPG',
  10: 'Slovenia_10.jpg',
  11: 'Slovenia_11.JPG',
};

const s = (n: number) => `/images/work/toward-the-blue/${files[n]}`;

type Photo = { src: string; n: number };
type Spread = {
  type: 'row' | 'single';
  photos: Photo[];
  caption?: string;
  captionStyle?: 'prose';
};

const spreads: Spread[] = [
  { type: 'row',    photos: [{ src: s(1), n: 1 }, { src: s(2), n: 2 }] },
  { type: 'single', photos: [{ src: s(3), n: 3 }] },
  { type: 'row',    photos: [{ src: s(4), n: 4 }, { src: s(5), n: 5 }, { src: s(6), n: 6 }] },
  { type: 'row',    photos: [{ src: s(7), n: 7 }, { src: s(8), n: 8 }] },
  { type: 'single', photos: [{ src: s(9), n: 9 }] },
  { type: 'row',    photos: [{ src: s(10), n: 10 }, { src: s(11), n: 11 }] },
];
---

<Layout
  title="Toward the Blue — Laurie Di Francesco"
  description="Toward the Blue — a photographic series by Laurie Di Francesco."
  image="/images/work/toward-the-blue-cover.jpg"
>

  <!-- ── Hero ─────────────────────────────────────────────── -->
  <section class="phero">
    <div class="phero-bg" aria-hidden="true">
      <img
        src="/images/work/toward-the-blue/Slovenia_5.JPG"
        alt=""
        loading="eager"
      />
    </div>
    <div class="phero-inner container">
      <p class="phero-eyebrow">Sky-blue in her eyes</p>
      <h1>Toward<br /><strong>the Blue</strong></h1>
    </div>
  </section>

  <!-- ── Intro ─────────────────────────────────────────────── -->
  <section class="intro">

    <!-- Épigraphe — à ajouter -->
    <!-- <blockquote class="epi">
      <p class="epi-text">…</p>
      <cite>Auteur</cite>
    </blockquote> -->

    <!-- Texte de présentation — à ajouter -->
    <!-- <p class="intro-text">…</p> -->

  </section>

  <!-- ── Série photographique ──────────────────────────────── -->
  <div class="series">
    {spreads.map((spread) => (
      <>
        <div class={`spread spread--${spread.type} rv`}>
          {spread.photos.map((photo) => (
            <figure class={photo.figClass}>
              <img
                src={photo.src}
                data-full={photo.src}
                alt={`Toward the Blue — photo ${photo.n}`}
                loading="lazy"
              />
            </figure>
          ))}
        </div>
        {spread.caption && (
          <p class={`series-caption${spread.captionStyle === 'prose' ? ' series-caption--prose' : ''} rv`}>
            {spread.caption}
          </p>
        )}
      </>
    ))}
  </div>

  <!-- ── Projet suivant ─────────────────────────────────────── -->
  <div class="next-project container">
    <span class="next-label">Next project</span>
    <a href="/work/vedere-venezia">Vedere Venezia e Non Morire →</a>
  </div>

</Layout>

<style is:global>

  /* ── Hero projet ──────────────────────────────────── */
  .phero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: flex-end;
    padding-bottom: clamp(3rem, 8vh, 6rem);
    overflow: hidden;
  }

  .phero-bg {
    position: absolute;
    inset: 0;
    z-index: -2;
  }

  .phero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .phero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(20,32,43,.18) 0%, rgba(20,32,43,0) 38%, rgba(20,32,43,.62) 100%);
  }

  .phero-inner {
    position: relative;
    color: #fff;
  }

  .phero-eyebrow {
    font-family: var(--font-body);
    font-size: .74rem;
    text-transform: uppercase;
    letter-spacing: .2em;
    color: rgba(255,255,255,.88);
    margin-bottom: .7rem;
  }

  .phero-inner h1 {
    font-family: var(--font-title);
    font-weight: 300;
    text-transform: uppercase;
    font-size: clamp(2rem, 7vw, 4.6rem);
    line-height: 1.02;
    letter-spacing: clamp(.04em, .8vw, .12em);
  }

  .phero-inner h1 strong { font-weight: 500; }

  /* ── Intro ────────────────────────────────────────── */
  .intro {
    max-width: 1320px;
    margin-top: clamp(3rem, 8vh, 5.5rem);
    margin-bottom: clamp(1.5rem, 3vh, 2.5rem);
    margin-left: auto;
    margin-right: auto;
    padding: 0 var(--gutter);
  }

  .intro-text {
    font-size: clamp(.9rem, 1.3vw, 1.05rem);
    line-height: 1.75;
    color: var(--encre);
    margin-bottom: 1.4rem;
    text-align: justify;
  }

  .intro-text em { font-style: italic; }

  .epi {
    border-left: 2px solid var(--cerule);
    padding: .2rem 0 .2rem 1.3rem;
    margin-bottom: 2rem;
  }

  .epi-text {
    color: var(--ardoise);
    font-size: clamp(.88rem, 1.2vw, 1rem);
    line-height: 1.9;
    font-style: italic;
    white-space: pre-line;
  }

  .epi cite {
    display: block;
    margin-top: .9rem;
    font-style: normal;
    font-size: .7rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--cerule);
  }

  .series-caption {
    font-family: var(--font-title);
    font-weight: 300;
    color: var(--cerule);
    font-size: clamp(1rem, 1.8vw, 1.35rem);
    line-height: 1.4;
    max-width: 1320px;
    margin: 1.5rem auto;
    padding: 0 var(--gutter);
    text-align: justify;
  }

  .series-caption--prose {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: clamp(.9rem, 1.3vw, 1.05rem);
    color: var(--encre);
    line-height: 1.75;
  }

  /* ── Série ────────────────────────────────────────── */
  .series {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 var(--gutter);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .spread {
    display: flex;
    gap: 16px;
    margin: 0;
    align-items: flex-start;
  }

  .spread figure {
    position: relative;
    flex-grow: 1;
    flex-basis: 0;
    min-width: 0;
    margin: 0;
  }

  .spread figure img {
    display: block;
    width: 100%;
    height: auto;
    cursor: zoom-in;
  }

  .spread--single figure { flex: 1 1 100%; }

  /* Scroll fade-in */
  .rv {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity .8s ease, transform .8s ease;
  }

  .rv.in {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .rv { opacity: 1; transform: none; transition: none; }
  }

  /* ── Next project ─────────────────────────────────── */
  .next-project {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    border-top: 1px solid var(--brume);
    padding-block: clamp(3rem, 8vh, 6rem);
    margin-top: clamp(2rem, 5vh, 3rem);
  }

  .next-label {
    font-family: var(--font-body);
    font-size: .72rem;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--ardoise);
  }

  .next-project a {
    font-family: var(--font-title);
    font-weight: 400;
    font-size: clamp(1.3rem, 3vw, 2rem);
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--encre);
    transition: color .3s;
  }

  .next-project a:hover { color: var(--cerule); }

  /* ── Mobile ───────────────────────────────────────── */
  @media (max-width: 700px) {
    .series { gap: 8px; }
    .spread { flex-wrap: wrap; gap: 8px; }
    .spread figure {
      flex: none !important;
      width: calc(50% - 4px) !important;
      transform: none !important;
      margin: 0 !important;
    }
    .spread--single figure { width: 100% !important; }
  }

  /* ── Lightbox ─────────────────────────────────────── */
  .lb { position: fixed; inset: 0; background: rgba(20,32,43,.94); display: none; align-items: center; justify-content: center; z-index: 200; }
  .lb.open { display: flex; }
  .lb-photo { max-width: min(86vw, calc(100vw - 5.5rem)); max-height: 92vh; width: auto; height: auto; object-fit: contain; border-radius: 4px; display: block; }
  .lb-nav { position: absolute; top: 50%; transform: translateY(-50%); background: none; border: none; padding: 1rem .7rem; cursor: pointer; color: rgba(255,255,255,.45); transition: color .25s; line-height: 0; -webkit-tap-highlight-color: transparent; }
  .lb-nav:hover { color: rgba(255,255,255,.9); }
  .lb-nav svg { width: clamp(1.5rem, 3vw, 2.2rem); height: clamp(1.5rem, 3vw, 2.2rem); display: block; }
  .lb-prev { left: .5rem; }
  .lb-next { right: .5rem; }
</style>

<script>
  // Justified row layout
  function justify() {
    const mob = window.innerWidth <= 700;
    document.querySelectorAll<HTMLElement>('.spread--row').forEach(row => {
      const figs = Array.from(row.querySelectorAll<HTMLElement>('figure'));
      const imgs = figs.map(f => f.querySelector('img') as HTMLImageElement);
      function apply() {
        if (mob) { figs.forEach(f => { f.style.flexGrow = ''; }); return; }
        const asp = imgs.map(im =>
          (im.naturalWidth && im.naturalHeight) ? im.naturalWidth / im.naturalHeight : 1
        );
        figs.forEach((f, i) => { f.style.flexGrow = asp[i].toFixed(4); });
      }
      if (imgs.every(im => im.complete && im.naturalWidth)) apply();
      else imgs.forEach(im => im.addEventListener('load', apply));
    });
  }
  justify();
  window.addEventListener('resize', () => {
    clearTimeout((window as any)._jt);
    (window as any)._jt = setTimeout(justify, 150);
  });

  // Scroll reveal
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('in'); obs.unobserve(e.target); }
    });
  }, { threshold: .06 });
  document.querySelectorAll('.rv').forEach(el => obs.observe(el));

  // Lightbox
  const lbAll = Array.from(document.querySelectorAll<HTMLImageElement>('.series img'));
  let lbIdx = 0;
  const lb = document.createElement('div');
  lb.className = 'lb';
  lb.innerHTML = `<button class="lb-nav lb-prev" aria-label="Previous"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg></button><img class="lb-photo" /><button class="lb-nav lb-next" aria-label="Next"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg></button>`;
  document.body.appendChild(lb);
  const lbPhoto = lb.querySelector<HTMLImageElement>('.lb-photo')!;
  const lbPrev = lb.querySelector<HTMLButtonElement>('.lb-prev')!;
  const lbNext = lb.querySelector<HTMLButtonElement>('.lb-next')!;
  function lbShow(i: number) {
    lbIdx = Math.max(0, Math.min(i, lbAll.length - 1));
    lbPhoto.src = lbAll[lbIdx].dataset.full || lbAll[lbIdx].src;
    lbPrev.style.opacity = lbIdx > 0 ? '1' : '0';
    lbPrev.style.pointerEvents = lbIdx > 0 ? 'auto' : 'none';
    lbNext.style.opacity = lbIdx < lbAll.length - 1 ? '1' : '0';
    lbNext.style.pointerEvents = lbIdx < lbAll.length - 1 ? 'auto' : 'none';
  }
  function lbClose() { lb.classList.remove('open'); document.body.style.overflow = ''; }
  lbAll.forEach((im, i) => im.addEventListener('click', () => { lbShow(i); lb.classList.add('open'); document.body.style.overflow = 'hidden'; }));
  lbPrev.addEventListener('click', e => { e.stopPropagation(); lbShow(lbIdx - 1); });
  lbNext.addEventListener('click', e => { e.stopPropagation(); lbShow(lbIdx + 1); });
  lb.addEventListener('click', e => { if (e.target === lb || e.target === lbPhoto) lbClose(); });
  document.addEventListener('keydown', e => {
    if (!lb.classList.contains('open')) return;
    if (e.key === 'Escape') lbClose();
    if (e.key === 'ArrowLeft') lbShow(lbIdx - 1);
    if (e.key === 'ArrowRight') lbShow(lbIdx + 1);
  });
  let lbTX = 0;
  lb.addEventListener('touchstart', e => { lbTX = (e as any).touches[0].clientX; }, { passive: true });
  lb.addEventListener('touchend', e => { const dx = lbTX - (e as any).changedTouches[0].clientX; if (Math.abs(dx) > 50) { dx > 0 ? lbShow(lbIdx + 1) : lbShow(lbIdx - 1); } });
</script>
