---
import Layout from '../../../layouts/Layout.astro';

// ── Mot de passe — change la valeur entre guillemets ──────────
const PASSWORD = 'surfacing';

// Photos de la série publique
const pub = (n: number) => ({ src: `/images/work/en-corps-en-la-mer/${n}.jpg`, n });
// Photos privées — dépose les fichiers dans /public/images/work/ecm-private/
// puis ajoute prv(n) dans les spreads ci-dessous
const prv = (n: number) => ({ src: `/images/work/ecm-private/${n}.jpg`, n });

type Photo = { src: string; n: number };
type Spread = { type: 'row' | 'single'; photos: Photo[] };

// Série complète — pub(n) = photo publique · prv(n) = photo privée uniquement
const spreads: Spread[] = [
  // La chute — intérieur, maladie
  { type: 'row',    photos: [pub(51), pub(52)] },
  { type: 'row',    photos: [pub(53), prv(54), pub(56)] },
  // Les seuils — fenêtres, attente
  { type: 'row',    photos: [pub(55), pub(59)] },
  // Vers l'eau — la mer apparaît
  { type: 'row',    photos: [pub(57), pub(58), pub(60), pub(61)] },
  { type: 'single', photos: [pub(62)] },
  // L'immersion — le corps dans l'eau
  { type: 'row',    photos: [prv(63), pub(64), pub(65), pub(67)] },
  // Les signes — flottements, objets, le flamant
  { type: 'row',    photos: [pub(66), pub(70), pub(71), pub(72)] },
  { type: 'row',    photos: [pub(73), pub(74)] },
  // Refaire surface — vers la blancheur
  { type: 'row',    photos: [prv(68), pub(69)] },
  { type: 'row',    photos: [prv(75), pub(76)] },
];
---

<Layout
  title="En Corps à la Mer — Complete series"
  description=""
>

  <!-- ── Gate mot de passe ──────────────────────────────────── -->
  <div class="gate" id="gate">
    <div class="gate-inner">
      <p class="gate-eyebrow">En Corps à la Mer</p>
      <p class="gate-title">Complete series</p>
      <p class="gate-sub">Private access</p>
      <form class="gate-form" id="gate-form" autocomplete="off">
        <input
          type="password"
          id="pw"
          class="gate-input"
          placeholder="Password"
          aria-label="Password"
          autocomplete="current-password"
        />
        <button type="submit" class="gate-btn">Enter</button>
      </form>
      <p class="gate-error" id="gate-error" aria-live="polite"></p>
    </div>
  </div>

  <!-- ── Page projet (réplique) ─────────────────────────────── -->
  <div id="pgallery" aria-hidden="true" style="display:none">

    <!-- ── Hero ──────────────────────────────────────────────── -->
    <section class="phero">
      <div class="phero-bg" aria-hidden="true">
        <img src="/images/work/en-corps-en-la-mer/72.jpg" alt="" loading="eager" />
      </div>
      <div class="phero-inner container">
        <p class="phero-eyebrow">Surfacing · 2025 — Complete series</p>
        <h1>En Corps<br /><strong>à la Mer</strong></h1>
      </div>
    </section>

    <!-- ── Ouverture 2 colonnes ──────────────────────────────── -->
    <section class="opening container">

      <div class="opening-epi">

        <div class="epi-wrap">
          <blockquote>
            That fundamental artistic phenomenon which is called <span class="k">life</span>
          </blockquote>
          <cite>Friedrich Nietzsche — Posthumous Fragments</cite>
        </div>
        <hr class="horizon epi-horizon" />

        <div class="epi-wrap">
          <blockquote>
            <span class="k">Dreams and water are two worlds where I recover a little balance, a little lightness,
            where I live again the pleasure of movement.</span> Held within the water's sheath, my body
            lets go of its pain. It fades, dissolves, vanishes. My movements turn fluid, easy;
            my body supple, almost deft. Gone, the tender catching-points: the hips, the elbows —
            nothing rasps anymore, nothing chafes, nothing tears. I remember dreaming I was a mermaid.
            My legs were imprisoned in a cocoon formed by the sheets, wound tight from turning and
            turning on myself in search of a position without pain. In the dream, the mummification
            had been transfigured into a power of movement.
          </blockquote>
          <cite>Claire Marin — Hors de moi <span class="epi-tradfr">freely translated from the French</span></cite>
        </div>
        <hr class="horizon epi-horizon" />

      </div>

      <div class="opening-proj">
        <p class="opening-eyebrow">The project</p>
        <p class="opening-text">
          There was a season when the body gave way — when illness pulled the ground
          from under everything and strength drained off like a tide going out. <em>En Corps à la Mer</em> follows that long descent and its turning:
          force returning not through stillness, but through water. To swim was to
          be carried and to carry oneself at once — to surface, and surface again,
          until surfacing became a way of living. The series moves from dark
          interiors toward an open, dazzling white: the sea as the place where a
          life is handed back.
        </p>
        <hr class="horizon opening-horizon" />
      </div>

    </section>

    <!-- ── Série photographique ──────────────────────────────── -->
    <div class="series">
      {spreads.map((spread) => (
        <div class={`spread spread--${spread.type} rv`}>
          {spread.photos.map((photo) => (
            <figure>
              <img
                src={photo.src}
                data-full={photo.src}
                alt={`En Corps à la Mer — ${photo.n}`}
                loading="lazy"
              />
            </figure>
          ))}
        </div>
      ))}
    </div>

    <!-- ── Retour ─────────────────────────────────────────────── -->
    <div class="next-project container">
      <span class="next-label">Back</span>
      <a href="/work/en-corps-en-la-mer">En Corps à la Mer →</a>
    </div>

  </div>

</Layout>

<style is:global>

  /* ── Gate ──────────────────────────────────────────────── */
  .gate {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--encre);
  }

  .gate-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
    padding: 3rem;
    max-width: 380px;
    width: 100%;
  }

  .gate-eyebrow {
    font-family: var(--font-body);
    font-size: .68rem;
    text-transform: uppercase;
    letter-spacing: .22em;
    color: rgba(255,255,255,.45);
    text-align: center;
  }

  .gate-title {
    font-family: var(--font-title);
    font-weight: 300;
    font-size: clamp(1.4rem, 4vw, 2rem);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: #fff;
    text-align: center;
    line-height: 1.15;
  }

  .gate-sub {
    font-family: var(--font-body);
    font-size: .7rem;
    text-transform: uppercase;
    letter-spacing: .18em;
    color: var(--cerule);
    text-align: center;
  }

  .gate-form {
    display: flex;
    gap: .6rem;
    width: 100%;
    margin-top: .5rem;
  }

  .gate-input {
    flex: 1 1 0;
    background: rgba(255,255,255,.08);
    border: 1px solid rgba(255,255,255,.18);
    border-radius: 2px;
    padding: .65rem 1rem;
    font-family: var(--font-body);
    font-size: .85rem;
    color: #fff;
    outline: none;
    transition: border-color .2s;
  }

  .gate-input::placeholder { color: rgba(255,255,255,.35); }
  .gate-input:focus { border-color: var(--cerule); }

  .gate-btn {
    background: var(--cerule);
    border: none;
    border-radius: 2px;
    padding: .65rem 1.4rem;
    font-family: var(--font-body);
    font-size: .78rem;
    text-transform: uppercase;
    letter-spacing: .12em;
    color: #fff;
    cursor: pointer;
    transition: opacity .2s;
  }

  .gate-btn:hover { opacity: .85; }

  .gate-error {
    font-family: var(--font-body);
    font-size: .72rem;
    color: #e07070;
    min-height: 1em;
    text-align: center;
  }

  /* ── Hero projet ────────────────────────────────────── */
  .phero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: flex-end;
    padding-bottom: clamp(3rem, 8vh, 6rem);
    overflow: hidden;
  }

  .phero-bg {
    position: absolute;
    inset: 0;
    z-index: -2;
  }

  .phero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .phero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg,
        rgba(20,32,43,.45) 0%,
        rgba(20,32,43,0) 30%,
        rgba(20,32,43,0) 55%,
        rgba(20,32,43,.62) 100%
      );
  }

  .phero-inner {
    position: relative;
    color: #fff;
  }

  .phero-eyebrow {
    font-family: var(--font-body);
    font-size: .74rem;
    text-transform: uppercase;
    letter-spacing: .2em;
    color: rgba(255,255,255,.88);
    margin-bottom: .7rem;
  }

  .phero-inner h1 {
    font-family: var(--font-title);
    font-weight: 300;
    text-transform: uppercase;
    font-size: clamp(2rem, 7vw, 4.6rem);
    line-height: 1.02;
    letter-spacing: clamp(.04em, .8vw, .12em);
  }

  .phero-inner h1 strong { font-weight: 500; }

  /* ── Ouverture 2 colonnes ───────────────────────────── */
  .opening {
    display: flex;
    gap: 16px;
    align-items: stretch;
    padding-top: clamp(3rem, 8vh, 5.5rem);
    padding-bottom: clamp(3rem, 7vh, 5rem);
  }
  .opening.container { max-width: 1320px; }

  .opening-epi {
    flex: 1 1 0;
    display: flex;
    flex-direction: column;
  }

  .opening-proj {
    flex: 1 1 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  /* Citations — structure identique à Work/About */
  .epi-wrap {
    border-left: 2px solid var(--cerule);
    padding: .2rem 0 1.8rem 1.3rem;
    max-width: 60ch;
  }

  .epi-wrap + .epi-horizon + .epi-wrap {
    margin-top: 4.8rem;
  }

  .epi-wrap blockquote {
    font-family: var(--font-title);
    font-weight: 300;
    font-style: italic;
    font-size: clamp(.88rem, 1.2vw, 1rem);
    line-height: 1.55;
    color: var(--ardoise);
  }

  .epi-wrap .k { color: var(--cerule); font-weight: 500; }

  .epi-wrap cite {
    display: block;
    margin-top: .9rem;
    font-style: normal;
    font-size: .7rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--cerule);
  }

  .epi-tradfr {
    display: block;
    font-size: .62rem;
    letter-spacing: .08em;
    text-transform: none;
    font-style: italic;
    color: var(--ardoise);
    margin-top: .2rem;
  }

  .epi-horizon { margin-top: 0; }

  /* Colonne projet */
  .opening-eyebrow {
    font-family: var(--font-body);
    font-size: .72rem;
    text-transform: uppercase;
    letter-spacing: .2em;
    color: var(--cerule);
    margin-bottom: 1rem;
  }

  .opening-text {
    font-size: clamp(.92rem, 1.35vw, 1.06rem);
    line-height: 1.78;
    color: var(--encre);
    text-align: justify;
    hyphens: auto;
    -webkit-hyphens: auto;
    flex-grow: 1;
    margin-bottom: 1.8rem;
  }

  .opening-text em { font-style: italic; }
  .opening-horizon { margin-top: 0; }

  /* ── Série ──────────────────────────────────────────── */
  .series {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 var(--gutter);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .spread {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .spread figure {
    flex-grow: 1;
    flex-basis: 0;
    min-width: 0;
    margin: 0;
  }

  .spread figure img {
    display: block;
    width: 100%;
    height: auto;
    cursor: zoom-in;
  }

  .spread--single figure { flex: 1 1 100%; }

  /* Scroll fade-in */
  .rv {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity .8s ease, transform .8s ease;
  }
  .rv.in { opacity: 1; transform: none; }

  @media (prefers-reduced-motion: reduce) {
    .rv { opacity: 1; transform: none; transition: none; }
  }

  /* ── Next / Back ────────────────────────────────────── */
  .next-project {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    border-top: 1px solid var(--brume);
    padding-block: clamp(3rem, 8vh, 6rem);
    margin-top: clamp(2rem, 5vh, 3rem);
  }

  .next-label {
    font-family: var(--font-body);
    font-size: .72rem;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--ardoise);
  }

  .next-project a {
    font-family: var(--font-title);
    font-weight: 400;
    font-size: clamp(1.3rem, 3vw, 2rem);
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--encre);
    transition: color .3s;
  }

  .next-project a:hover { color: var(--cerule); }

  /* ── Mobile ─────────────────────────────────────────── */
  @media (max-width: 700px) {
    .opening { flex-direction: column; gap: 2.5rem; }
    .opening-epi { justify-content: flex-start; }
    .series { gap: 8px; }
    .spread { flex-wrap: wrap; gap: 8px; }
    .spread figure { flex: none !important; width: calc(50% - 4px) !important; }
    .spread--single figure { width: 100% !important; }
    .gate-form { flex-direction: column; }
    .gate-btn { width: 100%; }
  }

  /* ── Lightbox ───────────────────────────────────────── */
  .lb {
    position: fixed;
    inset: 0;
    background: rgba(20,32,43,.94);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 200;
    padding: 3vw;
    cursor: zoom-out;
  }
  .lb.open { display: flex; }
  .lb img {
    max-width: 96vw;
    max-height: 94vh;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 4px;
  }

</style>

<script define:vars={{ PASSWORD }}>
  const form    = document.getElementById('gate-form');
  const gate    = document.getElementById('gate');
  const gallery = document.getElementById('pgallery');
  const errEl   = document.getElementById('gate-error');

  function unlock() {
    gate.style.display = 'none';
    gallery.style.display = 'block';
    gallery.removeAttribute('aria-hidden');
    initPage();
  }

  if (sessionStorage.getItem('ecm-private-auth') === '1') unlock();

  form.addEventListener('submit', e => {
    e.preventDefault();
    const pw = document.getElementById('pw').value;
    if (pw === PASSWORD) {
      sessionStorage.setItem('ecm-private-auth', '1');
      unlock();
    } else {
      errEl.textContent = 'Incorrect password.';
    }
  });

  function initPage() {
    // Justified row layout
    function justify() {
      const mob = window.innerWidth <= 700;
      document.querySelectorAll('.spread--row').forEach(row => {
        const figs = Array.from(row.querySelectorAll('figure'));
        const imgs = figs.map(f => f.querySelector('img'));
        function apply() {
          if (mob) { figs.forEach(f => { f.style.flexGrow = ''; }); return; }
          imgs.forEach((im, i) => {
            const r = (im.naturalWidth && im.naturalHeight) ? im.naturalWidth / im.naturalHeight : 1;
            figs[i].style.flexGrow = r.toFixed(4);
          });
        }
        if (imgs.every(im => im.complete && im.naturalWidth)) apply();
        else imgs.forEach(im => im.addEventListener('load', apply));
      });
    }
    justify();
    window.addEventListener('resize', () => {
      clearTimeout(window._jt);
      window._jt = setTimeout(justify, 150);
    });

    // Scroll reveal
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('in'); obs.unobserve(e.target); }
      });
    }, { threshold: .06 });
    document.querySelectorAll('.rv').forEach(el => obs.observe(el));

    // Lightbox
    const lb = document.createElement('div');
    lb.className = 'lb';
    const lbImg = document.createElement('img');
    lb.appendChild(lbImg);
    document.body.appendChild(lb);
    document.querySelectorAll('.series img').forEach(im => {
      im.addEventListener('click', () => {
        lbImg.src = im.dataset.full || im.src;
        lb.classList.add('open');
      });
    });
    lb.addEventListener('click', () => lb.classList.remove('open'));
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') lb.classList.remove('open');
    });
  }
</script>
