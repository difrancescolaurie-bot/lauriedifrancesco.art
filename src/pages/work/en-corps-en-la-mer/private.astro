---
import Layout from '../../../layouts/Layout.astro';

// Numéros des photos privées — ajoute ici les numéros quand tu déposes les photos dans /public/images/work/ecm-private/
const privatePhotos: number[] = [];
---

<Layout
  title="En Corps en la Mer — Série complète"
  description=""
>

  <!-- ── Gate mot de passe ──────────────────────────────── -->
  <div class="gate" id="gate">
    <div class="gate-inner">
      <p class="gate-eyebrow">En Corps en la Mer</p>
      <p class="gate-title">Série complète</p>
      <p class="gate-sub">Accès privé</p>
      <form class="gate-form" id="gate-form" autocomplete="off">
        <input
          type="password"
          id="pw"
          class="gate-input"
          placeholder="Mot de passe"
          aria-label="Mot de passe"
          autocomplete="current-password"
        />
        <button type="submit" class="gate-btn">Entrer</button>
      </form>
      <p class="gate-error" id="gate-error" aria-live="polite"></p>
    </div>
  </div>

  <!-- ── Galerie privée (cachée jusqu'au bon mdp) ───────── -->
  <div class="pgallery" id="pgallery" aria-hidden="true" style="display:none">

    <section class="pg-head container">
      <a href="/work/en-corps-en-la-mer" class="pg-back">← En Corps en la Mer</a>
      <p class="pg-eyebrow">Surfacing · 2025</p>
      <h1>En Corps<br /><strong>en la Mer</strong></h1>
      <p class="pg-sub">Série complète — accès privé</p>
      <hr class="horizon pg-horizon" />
    </section>

    {privatePhotos.length === 0 ? (
      <p class="pg-empty container">Photos à venir — dépose les fichiers dans <code>/public/images/work/ecm-private/</code> et ajoute leurs numéros dans le tableau <code>privatePhotos</code> de cette page.</p>
    ) : (
      <div class="pg-series">
        {privatePhotos.map(n => (
          <figure class="pg-fig">
            <img
              src={`/images/work/ecm-private/${n}.jpg`}
              data-full={`/images/work/ecm-private/${n}.jpg`}
              alt={`En Corps en la Mer — ${n}`}
              loading="lazy"
            />
          </figure>
        ))}
      </div>
    )}

  </div>

</Layout>

<style is:global>

  /* ── Gate ──────────────────────────────────────────── */
  .gate {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--encre);
  }

  .gate-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
    padding: 3rem;
    max-width: 380px;
    width: 100%;
  }

  .gate-eyebrow {
    font-family: var(--font-body);
    font-size: .68rem;
    text-transform: uppercase;
    letter-spacing: .22em;
    color: rgba(255,255,255,.45);
    text-align: center;
  }

  .gate-title {
    font-family: var(--font-title);
    font-weight: 300;
    font-size: clamp(1.4rem, 4vw, 2rem);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: #fff;
    text-align: center;
    line-height: 1.15;
  }

  .gate-sub {
    font-family: var(--font-body);
    font-size: .7rem;
    text-transform: uppercase;
    letter-spacing: .18em;
    color: var(--cerule);
    text-align: center;
  }

  .gate-form {
    display: flex;
    gap: .6rem;
    width: 100%;
    margin-top: .5rem;
  }

  .gate-input {
    flex: 1 1 0;
    background: rgba(255,255,255,.08);
    border: 1px solid rgba(255,255,255,.18);
    border-radius: 2px;
    padding: .65rem 1rem;
    font-family: var(--font-body);
    font-size: .85rem;
    color: #fff;
    outline: none;
    transition: border-color .2s;
  }

  .gate-input::placeholder { color: rgba(255,255,255,.35); }
  .gate-input:focus { border-color: var(--cerule); }

  .gate-btn {
    background: var(--cerule);
    border: none;
    border-radius: 2px;
    padding: .65rem 1.4rem;
    font-family: var(--font-body);
    font-size: .78rem;
    text-transform: uppercase;
    letter-spacing: .12em;
    color: #fff;
    cursor: pointer;
    transition: opacity .2s;
  }

  .gate-btn:hover { opacity: .85; }

  .gate-error {
    font-family: var(--font-body);
    font-size: .72rem;
    color: #e07070;
    min-height: 1em;
    text-align: center;
  }

  /* ── Galerie privée ─────────────────────────────────── */
  .pg-head {
    padding-top: clamp(5rem, 12vh, 8rem);
    padding-bottom: clamp(2rem, 5vh, 3.5rem);
  }

  .pg-back {
    display: block;
    font-family: var(--font-body);
    font-size: .7rem;
    text-transform: uppercase;
    letter-spacing: .14em;
    color: var(--ardoise);
    margin-bottom: 2rem;
    transition: color .2s;
  }

  .pg-back:hover { color: var(--cerule); }

  .pg-eyebrow {
    font-family: var(--font-body);
    font-size: .72rem;
    text-transform: uppercase;
    letter-spacing: .2em;
    color: var(--cerule);
    margin-bottom: .6rem;
  }

  .pg-head h1 {
    font-family: var(--font-title);
    font-weight: 300;
    text-transform: uppercase;
    font-size: clamp(2rem, 6vw, 3.8rem);
    line-height: 1.02;
    letter-spacing: clamp(.04em, .8vw, .12em);
    color: var(--encre);
    margin-bottom: .8rem;
  }

  .pg-head h1 strong { font-weight: 500; }

  .pg-sub {
    font-family: var(--font-body);
    font-size: .72rem;
    text-transform: uppercase;
    letter-spacing: .18em;
    color: var(--ardoise);
    margin-bottom: 0;
  }

  .pg-horizon { margin-top: 1.6rem; }

  .pg-series {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 var(--gutter) clamp(4rem, 10vh, 7rem);
    columns: 2;
    column-gap: 12px;
  }

  .pg-fig {
    break-inside: avoid;
    margin: 0 0 12px;
  }

  .pg-fig img {
    display: block;
    width: 100%;
    height: auto;
    cursor: zoom-in;
  }

  .pg-empty {
    padding: 3rem var(--gutter);
    font-family: var(--font-body);
    font-size: .85rem;
    color: var(--ardoise);
    line-height: 1.7;
  }

  .pg-empty code {
    font-family: monospace;
    font-size: .8em;
    background: rgba(0,0,0,.06);
    padding: .1em .3em;
    border-radius: 2px;
  }

  @media (max-width: 680px) {
    .pg-series { columns: 1; }
    .gate-form { flex-direction: column; }
    .gate-btn { width: 100%; }
  }

  /* ── Lightbox ─────────────────────────────────────── */
  .lb {
    position: fixed;
    inset: 0;
    background: rgba(20,32,43,.94);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 200;
    padding: 3vw;
    cursor: zoom-out;
  }
  .lb.open { display: flex; }
  .lb img {
    max-width: 96vw;
    max-height: 94vh;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 4px;
  }

</style>

<script>
  // ── Mot de passe — modifie cette ligne pour changer le code ──
  const PASSWORD = 'surfacing';

  const form    = document.getElementById('gate-form') as HTMLFormElement;
  const gate    = document.getElementById('gate') as HTMLElement;
  const gallery = document.getElementById('pgallery') as HTMLElement;
  const errEl   = document.getElementById('gate-error') as HTMLElement;

  function unlock() {
    gate.style.display = 'none';
    gallery.style.display = 'block';
    gallery.removeAttribute('aria-hidden');
  }

  if (sessionStorage.getItem('ecm-private-auth') === '1') unlock();

  form.addEventListener('submit', e => {
    e.preventDefault();
    const pw = (document.getElementById('pw') as HTMLInputElement).value;
    if (pw === PASSWORD) {
      sessionStorage.setItem('ecm-private-auth', '1');
      unlock();
    } else {
      errEl.textContent = 'Mot de passe incorrect.';
    }
  });

  // Lightbox
  const lb = document.createElement('div');
  lb.className = 'lb';
  const lbImg = document.createElement('img');
  lb.appendChild(lbImg);
  document.body.appendChild(lb);
  document.querySelectorAll<HTMLImageElement>('.pg-series img').forEach(im => {
    im.addEventListener('click', () => {
      lbImg.src = im.dataset.full || im.src;
      lb.classList.add('open');
    });
  });
  lb.addEventListener('click', () => lb.classList.remove('open'));
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') lb.classList.remove('open');
  });
</script>
