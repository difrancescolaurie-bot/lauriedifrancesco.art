---
import Layout from '../../layouts/Layout.astro';

const s = (file: string) => `/images/work/vedere-venezia/${file}`;

type Photo = { src: string; n: number };
type Spread = {
  type: 'row' | 'single';
  photos: Photo[];
};

const p = (n: number): Photo => ({ src: s(`${n}.jpg`), n });

const spreads: Spread[] = [
  { type: 'row',    photos: [p(1), p(2)] },
  { type: 'single', photos: [p(3)] },
  { type: 'row',    photos: [p(4), p(5)] },
  { type: 'row',    photos: [p(6), p(7), p(8)] },
  { type: 'single', photos: [p(9)] },
  { type: 'row',    photos: [p(10), p(11)] },
  { type: 'single', photos: [p(12)] },
];
---

<Layout
  title="Vedere Venezia e Non Morire — Laurie Di Francesco"
  description="Vedere Venezia e Non Morire — Seeing Venice without dying from it. A city seen from over the cliché's shoulder."
  image="/images/work/vedere-venezia-cover.jpg"
>

  <!-- ── Hero ──────────────────────────────────────────────── -->
  <section class="phero">
    <div class="phero-bg" aria-hidden="true">
      <img src="/images/work/vedere-venezia/7.jpg" alt="" loading="eager" />
    </div>
    <div class="phero-inner container">
      <p class="phero-eyebrow">Rebirth. An attempt.</p>
      <h1>Vedere Venezia<br /><strong>e Non Morire</strong></h1>
    </div>
  </section>

  <!-- ── Ouverture 2 colonnes ──────────────────────────────── -->
  <section class="opening container">

    <!-- Colonne gauche : citation -->
    <div class="opening-epi">
      <div class="epi-wrap">
        <blockquote>
          [Citation à choisir]
        </blockquote>
        <cite>[Auteur — Source]</cite>
      </div>
      <hr class="horizon epi-horizon" />
    </div>

    <!-- Colonne droite : texte du projet -->
    <div class="opening-proj">
      <p class="opening-eyebrow">The project</p>
      <p class="opening-text">
        [Texte du projet à définir]
      </p>
      <hr class="horizon opening-horizon" />
    </div>

  </section>

  <!-- ── Série photographique ──────────────────────────────── -->
  {spreads.length > 0 && (
    <div class="series">
      {spreads.map((spread) => (
        <div class={`spread spread--${spread.type} rv`}>
          {spread.photos.map((photo) => (
            <figure>
              <img
                src={photo.src}
                alt={`Vedere Venezia e Non Morire — ${photo.n}`}
                loading="lazy"
              />
            </figure>
          ))}
        </div>
      ))}
    </div>
  )}

  <!-- ── Projet suivant ─────────────────────────────────────── -->
  <div class="next-project container">
    <span class="next-label">Next project</span>
    <a href="/work/en-corps-en-la-mer">En Corps à la Mer →</a>
  </div>

</Layout>

<style is:global>

  /* ── Hero projet ──────────────────────────────────── */
  .phero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: flex-end;
    padding-bottom: clamp(3rem, 8vh, 6rem);
    overflow: hidden;
  }

  .phero-bg {
    position: absolute;
    inset: 0;
    z-index: -2;
  }

  .phero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .phero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg,
        rgba(20,32,43,.45) 0%,
        rgba(20,32,43,0) 30%,
        rgba(20,32,43,0) 55%,
        rgba(20,32,43,.62) 100%
      );
  }

  .phero-inner {
    position: relative;
    color: #fff;
  }

  .phero-eyebrow {
    font-family: var(--font-body);
    font-size: .74rem;
    text-transform: uppercase;
    letter-spacing: .2em;
    color: rgba(255,255,255,.88);
    margin-bottom: .7rem;
  }

  .phero-inner h1 {
    font-family: var(--font-title);
    font-weight: 300;
    text-transform: uppercase;
    font-size: clamp(2rem, 7vw, 4.6rem);
    line-height: 1.02;
    letter-spacing: clamp(.04em, .8vw, .12em);
  }

  .phero-inner h1 strong { font-weight: 500; }

  /* ── Ouverture 2 colonnes ─────────────────────────── */
  .opening {
    display: flex;
    gap: clamp(2.5rem, 6vw, 5rem);
    align-items: stretch;
    padding-top: clamp(3rem, 8vh, 5.5rem);
    padding-bottom: clamp(3rem, 7vh, 5rem);
  }

  .opening-epi {
    flex: 1 1 0;
    display: flex;
    flex-direction: column;
  }

  .opening-proj {
    flex: 1.05 1 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  /* Citations — structure identique à Work/About/En Corps */
  .epi-wrap {
    border-left: 2px solid var(--cerule);
    padding: .2rem 0 .2rem 1.3rem;
    max-width: 60ch;
  }

  .epi-wrap blockquote {
    font-family: var(--font-title);
    font-weight: 300;
    font-style: italic;
    font-size: clamp(.88rem, 1.2vw, 1rem);
    line-height: 1.55;
    color: var(--ardoise);
  }

  .epi-wrap .k {
    color: var(--cerule);
    font-weight: 500;
  }

  .epi-wrap cite {
    display: block;
    margin-top: .9rem;
    font-style: normal;
    font-size: .7rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--cerule);
  }

  .epi-horizon {
    margin-top: 1.8rem;
  }

  /* Colonne projet */
  .opening-eyebrow {
    font-family: var(--font-body);
    font-size: .72rem;
    text-transform: uppercase;
    letter-spacing: .2em;
    color: var(--cerule);
    margin-bottom: 1rem;
  }

  .opening-text {
    font-size: clamp(.92rem, 1.35vw, 1.06rem);
    line-height: 1.78;
    color: var(--encre);
    text-align: justify;
    hyphens: auto;
    -webkit-hyphens: auto;
    flex-grow: 1;
    margin-bottom: 1.8rem;
  }

  .opening-text em { font-style: italic; }

  .opening-horizon {
    margin-top: 0;
  }

  /* ── Série ────────────────────────────────────────── */
  .series {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 var(--gutter);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .spread {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .spread figure {
    flex-grow: 1;
    flex-basis: 0;
    min-width: 0;
    margin: 0;
  }

  .spread figure img {
    display: block;
    width: 100%;
    height: auto;
  }

  .spread--single figure { flex: 1 1 100%; }

  /* Scroll fade-in */
  .rv {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity .8s ease, transform .8s ease;
  }
  .rv.in { opacity: 1; transform: none; }

  @media (prefers-reduced-motion: reduce) {
    .rv { opacity: 1; transform: none; transition: none; }
  }

  /* ── Next project ─────────────────────────────────── */
  .next-project {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    border-top: 1px solid var(--brume);
    padding-block: clamp(3rem, 8vh, 6rem);
    margin-top: clamp(2rem, 5vh, 3rem);
  }

  .next-label {
    font-family: var(--font-body);
    font-size: .72rem;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--ardoise);
  }

  .next-project a {
    font-family: var(--font-title);
    font-weight: 400;
    font-size: clamp(1.3rem, 3vw, 2rem);
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--encre);
    transition: color .3s;
  }

  .next-project a:hover { color: var(--cerule); }

  /* ── Mobile ───────────────────────────────────────── */
  @media (max-width: 700px) {
    .phero-bg img { object-position: 65% center; }
    .opening {
      flex-direction: column;
      gap: 2.5rem;
    }
    .series { gap: 8px; }
    .spread { flex-wrap: wrap; gap: 8px; }
    .spread figure {
      flex: none !important;
      width: calc(50% - 4px) !important;
    }
    .spread--single figure { width: 100% !important; }

    /* Trio : 3 colonnes égales pour éviter le blanc */
    .spread--row:has(figure:nth-child(3)) figure {
      width: calc(33.33% - 6px) !important;
    }

    /* Hauteur uniforme dans les rangées de 2 pour éviter le décalage */
    .spread--row:not(:has(figure:nth-child(3))) figure {
      aspect-ratio: 3 / 2;
      overflow: hidden;
    }
    .spread--row:not(:has(figure:nth-child(3))) figure img {
      height: 100%;
      object-fit: cover;
    }
  }

</style>

<script>
  // Justified row layout
  function justify() {
    const mob = window.innerWidth <= 700;
    document.querySelectorAll<HTMLElement>('.spread--row').forEach(row => {
      const figs = Array.from(row.querySelectorAll<HTMLElement>('figure'));
      const imgs = figs.map(f => f.querySelector('img') as HTMLImageElement);
      function apply() {
        if (mob) { figs.forEach(f => { f.style.flexGrow = ''; }); return; }
        imgs.forEach((im, i) => {
          const r = (im.naturalWidth && im.naturalHeight)
            ? im.naturalWidth / im.naturalHeight : 1;
          figs[i].style.flexGrow = r.toFixed(4);
        });
      }
      if (imgs.every(im => im.complete && im.naturalWidth)) apply();
      else imgs.forEach(im => im.addEventListener('load', apply));
    });
  }
  justify();
  window.addEventListener('resize', () => {
    clearTimeout((window as any)._jt);
    (window as any)._jt = setTimeout(justify, 150);
  });

  // Scroll reveal
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('in'); obs.unobserve(e.target); }
    });
  }, { threshold: .06 });
  document.querySelectorAll('.rv').forEach(el => obs.observe(el));
</script>
