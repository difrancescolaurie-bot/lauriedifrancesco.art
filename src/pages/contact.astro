---
import Layout from '../layouts/Layout.astro';
import '../styles/pages/contact.css';
---

<Layout
  title="Contact"
  description="Write to Laurie Di Francesco — commissions, collaborations, press."
>

  <!-- ── Titre ────────────────────────────────────────── -->
  <section class="ct-head container">
    <p class="ct-eyebrow">Contact</p>
    <h1 class="ct-h1">Write to me</h1>
    <p class="ct-sub">
      Commissions · Collaborations · Press
    </p>
  </section>

  <!-- ── Formulaire ────────────────────────────────────── -->
  <div class="ct-wrap">

    <form
      id="contact-form"
      action="https://api.web3forms.com/submit"
      method="POST"
      novalidate
    >
      <!-- Clé Web3Forms — à remplacer par la vraie clé après inscription -->
      <input type="hidden" name="access_key" value="6f50770e-29b1-49ab-804b-b759c8965999" />
      <!-- Redirection après envoi -->
      <input type="hidden" name="redirect" value="false" />
      <!-- Anti-spam honeypot -->
      <input type="checkbox" name="botcheck" class="ct-honeypot" aria-hidden="true" tabindex="-1" />

      <div class="ct-field">
        <label for="name">Name</label>
        <input type="text" id="name" name="name" required autocomplete="name" />
      </div>

      <div class="ct-field">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required autocomplete="email" />
      </div>

      <div class="ct-field">
        <label for="subject">Subject</label>
        <select id="subject" name="subject" required>
          <option value="" disabled selected>— choose —</option>
          <option value="Commission">Commission</option>
          <option value="Collaboration">Collaboration</option>
          <option value="Press">Press</option>
          <option value="Other">Other</option>
        </select>
      </div>

      <div class="ct-field">
        <label for="message">Message</label>
        <textarea id="message" name="message" rows="6" required></textarea>
      </div>

      <button type="submit" class="ct-btn">
        <span class="ct-btn-text">Send</span>
        <span class="ct-btn-arrow" aria-hidden="true">↗</span>
      </button>

      <!-- Feedback envoi -->
      <p class="ct-feedback" id="ct-feedback" aria-live="polite"></p>
    </form>

    <!-- ── Mention légale ──────────────────────────────── -->
    <p class="ct-legal">
      The information you submit is used solely to respond to your message.
      It is not shared with any third party.
    </p>

  </div>

</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const feedback = document.getElementById('ct-feedback') as HTMLElement;
  const btnText = form?.querySelector('.ct-btn-text') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btnText.textContent = 'Sending…';

    const data = new FormData(form);
    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: data,
      });
      const json = await res.json();
      if (json.success) {
        feedback.textContent = 'Your message has been sent. Thank you.';
        form.reset();
        btnText.textContent = 'Send';
      } else {
        feedback.textContent = 'Something went wrong. Please try again.';
        btnText.textContent = 'Send';
      }
    } catch {
      feedback.textContent = 'Network error. Please try again.';
      btnText.textContent = 'Send';
    }
  });
</script>
